local eHeld, mb2Held, mb3Held = false, false, false

UserInputService.InputBegan:Connect(function(input, processed)
    if input.KeyCode == Enum.KeyCode.E then eHeld = true
    elseif input.UserInputType == Enum.UserInputType.MouseButton2 then mb2Held = true
    elseif input.UserInputType == Enum.UserInputType.MouseButton3 then mb3Held = true
    elseif input.KeyCode == Enum.KeyCode.U and not processed then
        pcall(function() ReplicatedStorage.Remotes.Character.Reset:FireServer(true) end)
    elseif input.KeyCode == Enum.KeyCode.X and not processed then
        local target = CurrentTarget or GetClosestPlayer()
        if target and target.Character then
            ForceEnableShiftLock()
            local targetHrp = target.Character:FindFirstChild("HumanoidRootPart")
            if targetHrp then
                TweenTeleport(targetHrp.Position + targetHrp.CFrame.LookVector * -3, 0.3)
            end
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.E then eHeld = false
    elseif input.UserInputType == Enum.UserInputType.MouseButton2 then mb2Held = false
    elseif input.UserInputType == Enum.UserInputType.MouseButton3 then mb3Held = false
    end
end)

RunService.Heartbeat:Connect(function()
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    if not hrp or not humanoid then return end
    
    if mb3Held then hrp.CFrame = hrp.CFrame + Vector3.new(0, 2, 0) end
    if eHeld and humanoid.MoveDirection.Magnitude > 0 then
        local speed = mb2Held and 2 or 1
        hrp.CFrame = hrp.CFrame + humanoid.MoveDirection.Unit * speed
    end
end)


            Text = text,
            Duration = duration or 2
        })
    end)
end

local function EnableShiftLock()
    if ShiftLockEnabled then return end
    
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
    end)
    
    pcall(function()
        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    end)
    
    pcall(function()
        settings().GameSettings.RotationType = Enum.RotationType.CameraRelative
    end)
    
    pcall(function()
        local PlayerModule = require(LocalPlayer.PlayerScripts:WaitForChild("PlayerModule"))
        local cameras = PlayerModule:GetCameras()
        if cameras then
            local ShiftLockController = cameras:GetShiftLock()
            if ShiftLockController then
                ShiftLockController:SetIsEnabled(true)
            end
        end
    end)
    
    pcall(function()
        local camera = workspace.CurrentCamera
        if camera then
            camera.CameraType = Enum.CameraType.Custom
        end
    end)
    
    ShiftLockEnabled = true
end

local function DisableShiftLock()
    if not ShiftLockEnabled then return end
    
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
    end)
    
    pcall(function()
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        settings().GameSettings.RotationType = Enum.RotationType.MovementRelative
    end)
    
    ShiftLockEnabled = false
end

local function ForceEnableShiftLock()
    task.spawn(function()
        for _ = 1, 2 do
            EnableShiftLock()
            task.wait(0.05)
            if UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter then
                return
            end
        end
        pcall(function()
            UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
            settings().GameSettings.RotationType = Enum.RotationType.CameraRelative
        end)
    end)
end

local function TweenTeleport(targetPosition, duration)
    duration = duration or 0.3
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    ForceEnableShiftLock()
    
    local tweenInfo = TweenInfo.new(
        duration,
        Enum.EasingStyle.Quad,
        Enum.EasingDirection.Out
    )
    
    local tween = TweenService:Create(hrp, tweenInfo, {
        CFrame = CFrame.new(targetPosition)
    })
    
    tween:Play()
    return tween
end

local function IsPlayerAlive(player)
    if not player or not player.Character then 
        return false 
    end
    
    local humanoid = player.Character:FindFirstChild("Humanoid")
    if not humanoid then 
        return false 
    end
    
    local health = humanoid:GetAttribute("Health") or humanoid.Health
    return health > 0
end

local function GetAlivePlayers()
    local alivePlayers = {}
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        
        if IsPlayerAlive(player) then
            table.insert(alivePlayers, player)
        end
    end
    
    return alivePlayers
end

local function GetClosestPlayer()
    local character = LocalPlayer.Character
    if not character then return nil end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    local closest = nil
    local closestDist = math.huge
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local targetChar = player.Character
            if targetChar then
                local targetHrp = targetChar:FindFirstChild("HumanoidRootPart")
                if targetHrp and IsPlayerAlive(player) then
                    local dist = (targetHrp.Position - hrp.Position).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closest = player
                    end
                end
            end
        end
    end
    
    return closest
end

local function GetPlayerList()
    local list = {"None"}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(list, player.Name)
        end
    end
    return list
end


local function GetDifferentServers()
    local servers = {}
    local success, result = pcall(function()
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    
    if success and result and result.data then
        for _, server in ipairs(result.data) do
            if server.id ~= game.JobId 
               and not VisitedServers[server.id] 
               and server.playing < server.maxPlayers 
               and server.playing > 0 then
                table.insert(servers, server)
            end
        end
    end
    
    return servers
end

local function HopToDifferentServer()
    print("🔍 Searching for different server...")
    Notify("🔍 Searching", "Finding new server...", 2)
    
    local servers = GetDifferentServers()
    
    if #servers > 0 then
        local targetServer = servers[math.random(1, #servers)]
        VisitedServers[targetServer.id] = true
        print("✅ Found server:", targetServer.id, "Players:", targetServer.playing)
        Notify("✅ Found Server", targetServer.playing .. " players", 2)
        task.wait(0.5)
        TeleportService:TeleportToPlaceInstance(game.PlaceId, targetServer.id, LocalPlayer)
    else
        print("⚠️ No different servers found, trying regular hop...")
        Notify("⚠️ No Servers", "Trying regular hop...", 2)
        task.wait(0.5)
        TeleportService:Teleport(game.PlaceId, LocalPlayer)
    end
end

local function SmoothCountdownAndHop(seconds)
    for i = seconds,1,-1 do
        Notify("⏱️ Server Hop", "Hopping in "..i.." seconds...", 1)
        task.wait(1)
    end
    HopToDifferentServer()
end


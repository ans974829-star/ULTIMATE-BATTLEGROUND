-- MAIN FARM LOOP
RunService.RenderStepped:Connect(function(deltaTime)
    if not getgenv().SafeFarmEnabled and not getgenv().ServerFarmEnabled then return end
    
    if UserInputService.MouseBehavior ~= Enum.MouseBehavior.LockCenter then
        pcall(function()
            UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
        end)
    end
    
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local target = getgenv().FarmCurrentTarget
    local needNewTarget = false
    
    if not target then needNewTarget = true
    elseif not target.Character then needNewTarget = true
    elseif not target.Character:FindFirstChild("HumanoidRootPart") then needNewTarget = true
    elseif not target.Character:FindFirstChild("Humanoid") then needNewTarget = true
    else
        local humanoid = target.Character.Humanoid
        local health = humanoid:GetAttribute("Health") or humanoid.Health or 0
        if health <= 0 then needNewTarget = true end
    end
    
    if needNewTarget then
        if FarmTarget and FarmTarget.Character and FarmTarget.Character:FindFirstChild("Humanoid") then
            local h = FarmTarget.Character.Humanoid
            local hp = h:GetAttribute("Health") or h.Health or 0
            if hp > 0 then
                target = FarmTarget
                getgenv().FarmCurrentTarget = target
            end
        end
        
        if not target or needNewTarget then
            local alivePlayers = {}
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local hum = player.Character:FindFirstChild("Humanoid")
                    if hum then
                        local hp = hum:GetAttribute("Health") or hum.Health or 0
                        if hp > 0 then table.insert(alivePlayers, player) end
                    end
                end
            end
            if #alivePlayers > 0 then
                target = alivePlayers[math.random(1, #alivePlayers)]
                getgenv().FarmCurrentTarget = target
                getgenv().FarmSwitchTimer = 0
            else return end
        end
    end
    
    if target and target.Character then
        local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
        if targetHRP then
            local backPosition = targetHRP.Position - targetHRP.CFrame.LookVector * 3
            hrp.CFrame = CFrame.new(backPosition) + Vector3.new(0, 3, 0)
        end
    end
    
    getgenv().FarmSwitchTimer = getgenv().FarmSwitchTimer + deltaTime
    if getgenv().FarmSwitchTimer >= 5 and not FarmTarget then
        getgenv().FarmCurrentTarget = nil
        getgenv().FarmSwitchTimer = 0
    end
    
    if getgenv().SafeFarmEnabled then
        getgenv().FarmHopTimer = getgenv().FarmHopTimer + deltaTime
        if getgenv().FarmHopTimer >= HopTime then
            getgenv().SafeFarmEnabled = false
            ShiftLockEnabled = false
            task.spawn(function()
                SmoothCountdownAndHop(10)
            end)
        end
    end
end)

